# Copy this file to backend/.env and fill in real values.

# Database — SQLite for local dev, Postgres for production.
DATABASE_URL=sqlite:///./agentmeet.db
# DATABASE_URL=postgresql://postgres:password@localhost:5432/agentmeet

# Auth
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Third-party API keys
OPENAI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
